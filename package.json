{
  "type": "module",
  "version": "1.22.1",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --mode=dev",
    "serve": "node serve.mjs",
    "test": "node --test test/*.test.js",
    "test:ui": "node --loader ./test/helpers/jsx-loader.mjs --test test/components/*.test.jsx",
    "bench": "node perf/bench-algorithms.mjs",
    "perftest": "node perf/run.mjs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null; git config push.followTags true 2>/dev/null; true"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@aws-sdk/s3-request-presigner": "^3.1051.0",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0"
  }
}
