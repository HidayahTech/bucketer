#!/bin/sh
# Pre-push hook — builds, runs the full test suite (unit + component + e2e), and ensures
# the current version tag exists and is pushed to the remote immediately.
#
# Reads stdin to detect tag-only pushes (recursive calls when the hook pushes the version
# tag itself) and skips the build/test cycle in those cases.
#
# The e2e browser layer is the ONLY suite that exercises the multipart upload-completion
# path (uploadMultipart runs inside the UploadQueue component closure, unreachable from
# unit/component tests). BUG-035 — a ReferenceError on every non-probe multipart
# completion — shipped in v1.29.0/v1.30.0 precisely because e2e was not gating pushes.
# npm run test:e2e self-builds to perf/ (gitignored), so it does not touch dist/.
#
# To override in an emergency (human operator only):
#   git push --no-verify
#
# This hook is configured automatically by `npm install` via the `prepare` script.

set -e

push_input=$(cat)
branch_refs=$(printf '%s\n' "$push_input" | grep -c 'refs/heads/' 2>/dev/null || true)

if [ "$branch_refs" -gt 0 ]; then
  echo "Building..."
  npm run build

  echo "Running tests..."
  npm test

  echo "Running component tests..."
  npm run test:ui

  echo "Running e2e (node + browser)..."
  npm run test:e2e

  echo "Tests passed — push proceeding."
fi

VERSION=$(node -p "require('./package.json').version")
TAG="v${VERSION}"
if git rev-parse "refs/tags/${TAG}" >/dev/null 2>&1; then
  echo "Tag ${TAG} already exists."
else
  git tag -a "${TAG}" -m "${TAG}"
  echo "Tag ${TAG} created."
  git push origin "refs/tags/${TAG}"
  echo "Tag ${TAG} pushed."
fi
